{
  "logDir": "./logs",
  "commandBlacklist": [
    "^apt-get upgrade",
    "curl.*\\|.*sh"
  ],
  "defaultTimeout": 60000,
  "servers": {
    "prod-web": {
      "desc": "Production Web Server (Jump Host)",
      "host": "10.0.0.5",
      "port": 22,
      "username": "deploy",
      "privateKeyPath": "./id_rsa_prod",
      "passphrase": "${SSH_KEY_PWD}",
      "strictHostKeyChecking": false,
      "workingDirectories": {
        "html": { "path": "/var/www/html", "desc": "Nginx Root" }
      },
      "proxyJump": {
        "host": "bastion.example.com",
        "username": "jumpuser",
        "password": "${JUMP_PWD}"
      }
    },
    "direct-ssh": {
      "desc": "Direct SSH with Password",
      "host": "192.168.1.59",
      "username": "root",
      "password": "${SERVER_PWD}"
    },
    "test-db": {
      "desc": "Read-only Test Database",
      "host": "192.168.1.50",
      "username": "tester",
      "password": "password123",
      "readOnly": true
    }
  }
}
