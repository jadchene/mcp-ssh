{
  "logDir": "./logs",
  "commandBlacklist": [
    "^apt-get upgrade",
    "curl.*\\|.*sh"
  ],
  "defaultTimeout": 60000,
  "servers": {
    "prod-web": {
      "desc": "生产环境 Web 服务器 (通过跳板机访问)",
      "host": "10.0.0.5",
      "port": 22,
      "username": "deploy",
      "privateKeyPath": "./id_rsa_prod",
      "passphrase": "${SSH_PASSPHRASE}",
      "strictHostKeyChecking": false,
      "workingDirectories": {
        "html": {
          "path": "/var/www/html",
          "desc": "Nginx 网页根目录"
        },
        "logs": {
          "path": "/var/log/nginx",
          "desc": "Nginx 访问与错误日志目录"
        }
      },
      "proxyJump": {
        "host": "47.91.x.x",
        "port": 22,
        "username": "jump-user",
        "password": "${JUMP_PWD}"
      }
    },
    "test-db": {
      "desc": "数据库测试服务器 (只读)",
      "host": "192.168.1.50",
      "username": "tester",
      "password": "password123",
      "readOnly": true
    }
  }
}
